@model Dashboard.Application.DTOs.BoardViewModel
@{
    Layout = null;
    const string LblEnds   = "Ends";
    const string LblStarts = "Starts";
    const string LblClears = "Clears";
    int nLive = 0, nSched = 0, nHigh = 0, nDead = 0;
}
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, maximum-scale=5.0" />
    <title>Enterprise Board — Project Tracker AI</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" crossorigin="anonymous">
    <style>
        @Html.Raw(System.IO.File.ReadAllText(System.IO.Path.Combine(System.IO.Directory.GetCurrentDirectory(), "wwwroot", "css", "board.css")))
    </style>
</head>
<body>
<div class="enterprise-board">
    <header class="board-header">
        <div class="board-header-brand">
            <div class="board-brand-icon"><i class="bi bi-grid-3x3-gap-fill"></i></div>
            <div class="board-brand-text">
                <div class="board-brand-name">SSCU · ITD</div>
                <div class="board-brand-sub">Project Tracker AI</div>
                <div class="board-brand-org">Istana Nurul Iman</div>
            </div>
        </div>
        <div class="board-clock-block">
            <div class="board-clock" id="eb-clock">@Model.CurrentTime</div>
            <div class="board-date" id="eb-date">@Model.CurrentDate</div>
            @if (!string.IsNullOrEmpty(Model.HijriDate))
            { <div class="board-hijri">@Model.HijriDate</div> }
            <div class="board-status-dot">System Online</div>
            @if (Model.IsPortfolioManager)
            { <div class="board-role-badge">🔒 Portfolio Manager</div> }
        </div>
    </header>

    <div class="hero-row eb-fade-in">
        @{ var allLive = Model.TodayEvents.Where(e => e.IsLive).ToList(); var liveEvents = allLive.Take(4).ToList(); }
        <div class="hero-card glass-panel glow-green">
            <div class="hero-card-label green"><span class="live-dot"></span> Now Happening <span style="font-size:var(--eb-fs-badge);opacity:.7;margin-left:auto;">@allLive.Count live</span></div>
            @if (liveEvents.Count > 0)
            {
                @foreach (var ev in liveEvents)
                {
                    <div class="hero-card-title" style="font-size:var(--eb-fs-event-title);margin-bottom:4px;"><span class="live-index">@(++nLive)</span> @ev.Title</div>
                    <div class="hero-card-meta" style="margin-bottom:8px;">
                        <span><i class="bi bi-clock"></i> @ev.StartTime – @ev.EndTime</span>
                        @if (!string.IsNullOrEmpty(ev.CategoryName))
                        { <span class="tc-category" style="background:@(ev.CategoryColor ?? "#3b82f6")">@ev.CategoryName</span> }
                        @if (!string.IsNullOrEmpty(ev.Stakeholder))
                        { <span class="tc-stakeholder"><i class="bi bi-person-badge"></i> @ev.Stakeholder</span> }
                    </div>
                    @if (ev.End.HasValue)
                    {
                        <div class="hero-card-countdown" style="font-size:var(--eb-fs-meta);margin-top:0;margin-bottom:12px;" data-countdown="@(new DateTimeOffset(ev.End.Value, TimeSpan.FromHours(8)).ToUnixTimeSeconds())" data-label="@LblEnds">—</div>
                    }
                }
            }
            else
            { <div class="hero-card-title">All clear</div> }
        </div>

        <div class="hero-card glass-panel glow-blue">
            <div class="hero-card-label blue">Up Next</div>
            @if (Model.RecentlyEndedEvent is not null)
            {
                <div class="hero-card-title">@Model.RecentlyEndedEvent.Title</div>
                <div class="hero-card-meta">
                    <span><i class="bi bi-clock"></i> @Model.RecentlyEndedEvent.StartTime – @Model.RecentlyEndedEvent.EndTime</span>
                    @if (!string.IsNullOrEmpty(Model.RecentlyEndedEvent.Location))
                    { <span><i class="bi bi-geo-alt"></i> @Model.RecentlyEndedEvent.Location</span> }
                </div>
                <div class="hero-card-countdown" style="color:var(--eb-text-3);">@Model.RecentlyEndedEvent.EndedAgo</div>
            }
            else if (Model.NextEvent is not null)
            {
                <div class="hero-card-title">@Model.NextEvent.Title</div>
                <div class="hero-card-meta">
                    <span><i class="bi bi-clock"></i> @Model.NextEvent.StartTime – @Model.NextEvent.EndTime</span>
                    @if (!string.IsNullOrEmpty(Model.NextEvent.Location))
                    { <span><i class="bi bi-geo-alt"></i> @Model.NextEvent.Location</span> }
                    <span><i class="bi bi-people"></i> @Model.NextEvent.ParticipantCount</span>
                </div>
                <div class="hero-card-countdown" data-countdown="@(new DateTimeOffset(Model.NextEvent.Start, TimeSpan.FromHours(8)).ToUnixTimeSeconds())" data-label="@LblStarts">—</div>
            }
            else
            { <div class="hero-card-title">All clear</div> }
        </div>
    </div>

    <div class="content-grid eb-fade-in">
        <div class="schedule-panel glass-panel">
            <div class="section-title"><i class="bi bi-calendar-check"></i> Today's Schedule <span style="display:inline-block;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.10);border-radius:12px;padding:1px 10px;font-size:var(--eb-fs-section);font-weight:700;margin-left:8px;">@Model.TodayEvents.Count</span></div>
            @if (Model.TodayEvents.Count > 0)
            {
                foreach (var ev in Model.TodayEvents.Where(e => !e.IsLive).OrderBy(e => e.IsEnded).Take(5))
                {
                    var catColor = ev.CategoryColor ?? "#3b82f6";
                    <div class="today-card @(ev.IsLive ? "tc-live" : ev.IsEnded ? "tc-ended" : "")" style="--tc-color: @catColor;cursor:pointer" data-event-id="@ev.Id" title="Click to edit">
                        <div class="tc-time-pillar">
                            <span class="tc-index">@(++nSched)</span>
                            <span class="tc-time-start">@ev.StartTime</span>
                            @if (ev.EndTime != null) { <span class="tc-time-end">→ @ev.EndTime</span> }
                            @if (ev.IsLive) { <span class="tc-live-dot"><span class="tc-live-pulse"></span>LIVE</span> }
                        </div>
                        <div class="tc-body">
                            <div class="tc-title">@ev.Title</div>
                            <div class="tc-meta">
                                @if (!string.IsNullOrEmpty(ev.CategoryName)) { <span class="tc-category" style="background:@catColor">@ev.CategoryName</span> }
                                @if (!string.IsNullOrEmpty(ev.Stakeholder)) { <span class="tc-stakeholder"><i class="bi bi-person-badge"></i> @ev.Stakeholder</span> }
                                @if (!string.IsNullOrEmpty(ev.Duration) && ev.Duration != "All Day") { <span class="tc-duration">@ev.Duration</span> }
                                @if (ev.IsEnded) { <span class="tc-done-badge">Done</span> }
                            </div>
                            @if (ev.IsEnded && ev.End.HasValue)
                            { <div class="tc-countdown-below" data-countdown="@(new DateTimeOffset(ev.End.Value.AddHours(2), TimeSpan.FromHours(8)).ToUnixTimeSeconds())" data-label="@LblClears">Clears —</div> }
                            else
                            { <div class="tc-countdown-below" data-countdown="@(new DateTimeOffset(ev.Start, TimeSpan.FromHours(8)).ToUnixTimeSeconds())" data-label="@LblStarts">Starts —</div> }
                        </div>
                    </div>
                }
            }
            else { <div class="eb-empty">No events scheduled for today</div> }
        </div>

        <div class="schedule-panel glass-panel">
            <div class="section-title"><i class="bi bi-calendar-week"></i> This Week's Highlights <span style="display:inline-block;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.10);border-radius:12px;padding:1px 10px;font-size:var(--eb-fs-section);font-weight:700;margin-left:8px;">@Model.WeekHighlights.Count</span></div>
            @if (Model.WeekHighlights.Count > 0)
            {
                <div class="highlights-grid">
                @foreach (var ev in Model.WeekHighlights.Take(6))
                {
                    var catColor = ev.CategoryColor ?? "#3b82f6";
                    <div class="highlight-card" style="--hl-color: @catColor;cursor:pointer" data-event-id="@ev.Id" title="Click to edit">
                        <div class="hl-date-badge">
                            <span class="hl-index">@(++nHigh)</span>
                            <span class="hl-day">@ev.Start.ToString("ddd")</span>
                            <span class="hl-date">@ev.Start.ToString("d MMM")</span>
                        </div>
                        <div class="hl-body">
                            <div class="hl-title">@ev.Title</div>
                            <div class="hl-meta">
                                @if (!string.IsNullOrEmpty(ev.CategoryName)) { <span class="hl-category" style="background:@catColor">@ev.CategoryName</span> }
                                <span class="hl-time"><i class="bi bi-clock"></i> @(ev.AllDay ? "All Day" : ev.StartTime)</span>
                            </div>
                            @if (!string.IsNullOrEmpty(ev.Stakeholder)) { <div class="hl-stakeholder"><i class="bi bi-person-badge"></i> @ev.Stakeholder</div> }
                            <div class="hl-countdown">
                                <i class="bi bi-hourglass-split"></i> <div class="hero-card-countdown" style="font-size:var(--eb-fs-meta);margin-top:0;margin-bottom:0;display:inline;" data-countdown="@(new DateTimeOffset(ev.Start, TimeSpan.FromHours(8)).ToUnixTimeSeconds())" data-label="@LblStarts">—</div>
                            </div>
                        </div>
                    </div>
                }
                </div>
            }
            else { <div class="eb-empty">No highlights this week</div> }
        </div>

        <div style="display:flex;flex-direction:column;gap:var(--eb-gap-lg);">
            <div class="glass-panel">
                <div class="section-title"><i class="bi bi-speedometer2"></i> At a Glance</div>
                @if (Model.IsPortfolioManager)
                {
                <div class="kpi-grid">
                    <div class="kpi-card kpi-blue"><div class="kpi-value">@Model.MeetingsToday</div><div class="kpi-label">Events Today</div></div>
                    <div class="kpi-card kpi-amber"><div class="kpi-value">@Model.UpcomingDeadlines.Count</div><div class="kpi-label">Deadlines</div></div>
                    <div class="kpi-card kpi-green"><div class="kpi-value">@Model.ActiveProjects</div><div class="kpi-label">Projects Active</div></div>
                    <div class="kpi-card @(Model.RisksRequiringAttention > 0 ? "kpi-red" : "kpi-green")"><div class="kpi-value">@Model.RisksRequiringAttention</div><div class="kpi-label">Risks to Watch</div></div>
                </div>
                }
                else
                {
                <div class="eb-empty" style="padding:12px;">Sign in as Portfolio Manager to see KPIs</div>
                }
                @if (Model.PrayerTimes.Count > 0)
                {
                    <div style="margin-top:20px;">
                        <div class="section-title"><i class="bi bi-moon-stars"></i> Prayer Times</div>
                        <div style="display:flex;flex-wrap:wrap;gap:10px;">
                            @foreach (var pt in Model.PrayerTimes)
                            {
                                var isCurrent = pt.Name == Model.CurrentPrayer;
                                <span style="padding:12px 20px;border-radius:8px;font-size:var(--eb-fs-section);@(isCurrent ? "background:rgba(201,168,76,.2);color:var(--eb-accent);border:1px solid rgba(201,168,76,.3);" : "color:var(--eb-text-2);")">@pt.Name @pt.Time</span>
                            }
                        </div>
                    </div>
                }
            </div>

            @if (Model.IsPortfolioManager)
            {
            <div class="glass-panel">
                <div class="section-title"><i class="bi bi-calendar2-x"></i> Project Deadlines <span style="display:inline-block;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.10);border-radius:12px;padding:1px 10px;font-size:var(--eb-fs-section);font-weight:700;margin-left:8px;">@Model.UpcomingDeadlines.Count</span></div>
                @if (Model.UpcomingDeadlines.Count > 0)
                {
                    foreach (var d in Model.UpcomingDeadlines.Take(5))
                    {
                        var urgency = d.DaysUntilDeadline <= 0 ? "overdue" : d.DaysUntilDeadline <= 1 ? "urgent" : d.DaysUntilDeadline <= 3 ? "soon" : "ok";
                        <div class="deadline-card @urgency" style="cursor:pointer" data-project-deadline="@d.ProjectTitle">
                            <div class="dl-countdown @urgency"><span class="dl-index-num">@(++nDead)</span><span class="dl-days">@(d.DaysUntilDeadline <= 0 ? "!" : d.DaysUntilDeadline + "d")</span><span class="dl-label">@(d.DaysUntilDeadline <= 0 ? "OVERDUE" : d.DaysUntilDeadline == 1 ? "day left" : "days left")</span></div>
                            <div class="dl-body">
                                <div class="dl-title">@d.ProjectTitle</div>
                                <div class="dl-meta">
                                    <span class="dl-owner"><i class="bi bi-person"></i> @d.Owner</span>
                                    <span class="dl-date"><i class="bi bi-flag"></i> @d.EndDate.ToString("d MMM")</span>
                                </div>
                                <div class="dl-progress"><div class="dl-progress-bar" style="width:@d.ProgressPercent%;background:@(d.ProgressPercent >= 80 ? "#22c55e" : d.ProgressPercent >= 50 ? "#f59e0b" : "#ef4444")"></div></div>
                            </div>
                        </div>
                    }
                }
                else { <div class="eb-empty">No upcoming deadlines</div> }
            </div>
            }

            <div class="glass-panel">
                <div class="section-title"><i class="bi bi-cpu"></i> System</div>
                <div style="font-size:var(--eb-fs-meta);color:var(--eb-text-2);">
                    <div style="margin-bottom:8px;"><span class="eb-refresh-indicator">Live</span></div>
                    <div style="font-size:0.7rem;color:var(--eb-text-3);">Auto-refresh: @Model.AutoRefreshSeconds s</div>
                    <button id="eb-theme-btn" class="btn btn-sm btn-outline-secondary mt-2" style="font-size:var(--eb-fs-meta);"><i class="bi bi-sun-fill"></i> Theme</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
<script>
    @Html.Raw(System.IO.File.ReadAllText(System.IO.Path.Combine(System.IO.Directory.GetCurrentDirectory(), "wwwroot", "js", "board.js")))
</script>
</body>
</html>
